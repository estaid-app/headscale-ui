FROM node:lts AS build

# arguments
ARG VERSION="master"

#environment variables
ENV PROJECT_NAME="headscale-ui"

# Set the staging environment
WORKDIR /staging/scripts
WORKDIR /staging
RUN chown 1000:1000 /staging

# Copy across the build scripts
COPY docker/production/scripts/* ./scripts/

# Set permissions for all scripts
RUN chown -R 0:0 scripts
RUN chmod -R 755 scripts

# Copy source from build context (repo root)
RUN mkdir -p /staging/${PROJECT_NAME}
COPY src/ ./${PROJECT_NAME}/src/
COPY static/ ./${PROJECT_NAME}/static/
COPY package.json package-lock.json svelte.config.js vite.config.js jsconfig.json postcss.config.cjs tailwind.config.cjs ./${PROJECT_NAME}/

# Build the image. This build runs as root
RUN /staging/scripts/1-image-build.sh

#####
## Second Image
#####

FROM alpine:latest

#environment variables
ENV PROJECT_NAME="headscale-ui"
ENV HTTP_PORT="8080"
ENV HTTPS_PORT="8443"

# Production Web Server port. Runs a self signed SSL certificate
EXPOSE 443

# Set the staging environment
WORKDIR /data
WORKDIR /web
WORKDIR /staging/scripts
WORKDIR /staging

# Copy across the scripts folder
COPY docker/production/scripts/* ./scripts/
# Copy default caddy config
COPY docker/production/Caddyfile /staging/Caddyfile
COPY --from=build /staging/${PROJECT_NAME}/build /web

RUN apk add --no-cache caddy

# Create a group and user
RUN addgroup -S appgroup && adduser -D appuser -G appgroup

RUN chown -R 0:0 scripts
RUN chmod -R 755 scripts

RUN chown -R appuser:appgroup /web
RUN chown -R appuser:appgroup /data

USER appuser

WORKDIR /data

ENTRYPOINT /bin/sh /staging/scripts/2-initialise.sh